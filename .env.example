# Copiez ce fichier vers .env.local et remplissez les valeurs
# depuis Supabase : Project Settings → API

# URL du projet (ex: https://xxxxx.supabase.co)
VITE_SUPABASE_URL=

# Clé publique "anon" — safe côté client (protégée par RLS)
VITE_SUPABASE_ANON_KEY=

# NE JAMAIS mettre la service_role key ici ni dans le frontend.
# Elle reste réservée aux Edge Functions / scripts serveur uniquement.
